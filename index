<script>
  /* Referral tracking — reads ?ref=PARTNERNAME from URL */
  (function() {
    const params = new URLSearchParams(window.location.search);
    const ref = params.get('ref') || params.get('referred_by') || '';
    if (ref) {
      const field = document.getElementById('scholar-referred-by');
      if (field) field.value = decodeURIComponent(ref);
    }
  })();

  function showDay(day, btn) {
    document.getElementById('day1-schedule').style.display = day === 1 ? 'block' : 'none';
    document.getElementById('day2-schedule').style.display = day === 2 ? 'block' : 'none';
    document.querySelectorAll('.day-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
  }

  function openForm(type) {
    document.getElementById('pathways').style.display = 'none';
    const section = document.getElementById('forms');
    section.style.display = 'block';
    ['scholar','partner','sponsor'].forEach(t => {
      document.getElementById('form-' + t).classList.remove('active');
    });
    document.getElementById('form-' + type).classList.add('active');
    section.scrollIntoView({ behavior: 'smooth' });
  }

  function closeForm() {
    document.getElementById('forms').style.display = 'none';
    document.getElementById('pathways').style.display = 'block';
    document.getElementById('pathways').scrollIntoView({ behavior: 'smooth' });
  }

  function handleSubmit(event, type) {
    event.preventDefault();
    const form = event.target;
    const btn = document.getElementById(type + '-submit');
    btn.textContent = 'Sending...';
    btn.disabled = true;

    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(response => {
      if (response.ok) {
        form.style.display = 'none';
        document.getElementById(type + '-success').style.display = 'block';
      } else {
        btn.textContent = 'Something went wrong — please try again';
        btn.disabled = false;
      }
    }).catch(() => {
      btn.textContent = 'Connection error — please try again';
      btn.disabled = false;
    });
  }

  /* Hide forms section on initial load */
  document.getElementById('forms').style.display = 'none';
</script>
</body>
</html>
